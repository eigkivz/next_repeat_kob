generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Apartment {
  id        String   @id @default(cuid())
  name      String
  phone     String
  address   String
  email     String?
  lineId    String?
  taxCode   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoomType {
  id        String   @id @default(cuid())
  name      String
  price     Int      @default(0)
  remark    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  status    String   @default("active")
  rooms     Room[]
}

model Room {
  id          String   @id @default(cuid())
  name        String
  towerName   String
  totalLevel  Int
  totalRoom   Int
  roomTypeId  String
  remark      String?
  status      String   @default("active")
  statusEmpty String   @default("empty")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  roomType    RoomType @relation(fields: [roomTypeId], references: [id])
}
