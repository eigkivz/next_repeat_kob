generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Apartment {
  id        String   @id @default(cuid())
  name      String
  phone     String
  address   String
  email     String?
  lineId    String?
  taxCode   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoomType {
  id        String   @id @default(cuid())
  name      String
  price     Int      @default(0)
  remark    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  status    String   @default("active")
  rooms     Room[]
}

model Room {
  id          String    @id @default(cuid())
  name        String
  towerName   String
  totalLevel  Int
  totalRoom   Int
  roomTypeId  String
  remark      String?
  status      String    @default("active")
  statusEmpty String    @default("empty")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bookings    Booking[]
  roomType    RoomType  @relation(fields: [roomTypeId], references: [id])
}

model Booking {
  id              String           @id @default(cuid())
  customerName    String
  customerPhone   String
  customerAddress String
  customerCardId  String
  customerGender  String
  status          String           @default("active")
  stayAt          DateTime
  stayUntil       DateTime?
  deposit         Int              @default(0)
  remark          String?
  roomId          String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  room            Room             @relation(fields: [roomId], references: [id])
  electricityLogs ElectricityLog[]
  waterLog        WaterLog[]
}

model ElectricityLog {
  id              String   @id @default(cuid())
  bookingId       String
  booking         Booking  @relation(fields: [bookingId], references: [id])
  electricityUnit Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WaterLog {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id])
  waterUnit Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MoneyAdded {
  id          String   @id @default(cuid())
  name        String
  description String?
  amount      Int
  status      String   @default("active") // active, inactive
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WaterAndElectricityPrice {
  id                      String   @id @default(cuid())
  waterPricePerUnit       Int
  electricityPricePerUnit Int
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}
